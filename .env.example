# Optional: full API origin + path (no trailing slash). Example:
# VITE_API_BASE_URL=http://localhost:4000/api
#
# If unset, the dev server uses `vite.config.ts` proxy: browser calls `/api` → http://localhost:4000
#
# Optional: Socket.io origin (no path). Dev default is same origin + `/socket.io` proxy to :4000.
# VITE_SOCKET_URL=http://localhost:4000
